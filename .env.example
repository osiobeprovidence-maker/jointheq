# Required APIs & Services
# -----------------------------------------------------------------------------

# GEMINI_API_KEY: Used for AI functionality.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

VITE_APP_URL=https://jointheq.sbs
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
VITE_APP_URL="http://localhost:3000"

# CONVEX: Deployment URL for Convex.
VITE_CONVEX_URL="https://your-project.convex.cloud"

# CONVEX: SITE URL for Convex (for storage/site endpoints)
VITE_CONVEX_SITE_URL="https://your-project.convex.site"

# GOOGLE_GENERATIVE_AI_API_KEY: Admin AI Chat
GOOGLE_GENERATIVE_AI_API_KEY="YOUR_KEY"
